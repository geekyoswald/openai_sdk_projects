OPENAI_API_KEY=
DEEPSEEK_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Telegram demo (optional; log_step still works without these)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Same URL you passed to setWebhook; clears Telegram’s pending queue on each app startup.
TELEGRAM_WEBHOOK_URL=
# Optional pause between step notifications (seconds, e.g. 0.5)
TELEGRAM_STEP_DELAY_SEC=0
