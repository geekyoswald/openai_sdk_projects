OPENAI_API_KEY=
DEEPSEEK_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Telegram demo (optional; log_step still works without these)
TELEGRAM_BOT_TOKEN=
# Numeric chat id (private: positive int from the user who /start’d the bot). Not your @username.
# After you message the bot, GET https://api.telegram.org/bot<token>/getUpdates → message.chat.id
TELEGRAM_CHAT_ID=
# Public URL Telegram will POST to (HTTPS), path must match your app, e.g. /telegramwebhook.
# Not the api.telegram.org/setWebhook link — only https://your.domain/telegramwebhook
TELEGRAM_WEBHOOK_URL=
# Logging for complai_sdr.* loggers: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Optional pause between step notifications (seconds, e.g. 0.5)
TELEGRAM_STEP_DELAY_SEC=0

# Sales Manager run budget (tool/model turns; default 28). Raise only if you add agents/tools.
# SDR_MAX_TURNS=28
